# Server
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/vip_mobility
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vip_mobility
DB_USER=postgres
DB_PASSWORD=password
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# App
PLATFORM_COMMISSION_RATE=0.20
INSURANCE_FEE_PER_DAY=25.00
MILEAGE_OVERAGE_RATE=2.00
SURGE_DEMAND_RATIO=1.5
SURGE_MULTIPLIER=1.2
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGIN=http://localhost:3001
